# Function to display the git branch
git_branch() {
    local branch
    branch=$(git branch --show-current 2>/dev/null)
    if [ -z "$branch" ]; then
        branch=$(git rev-parse --short HEAD 2>/dev/null) || return
    fi
    echo " ($branch)"
}

if [ "$EUID" -eq 0 ]; then
    PS1='\[\e[91;1m\]\u@\h\[\e[0m\]:\[\e[38;5;45m\]\w\[\e[38;5;208m\]$(git_branch)\[\e[0m\] '
else         
    PS1='\[\e[38;5;33;1m\]\u@\h\[\e[0m\]:\[\e[38;5;45m\]\w\[\e[38;5;202m\]$(git_branch)\[\e[0m\] '
fi